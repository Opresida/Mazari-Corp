modules = ["nodejs-24"]
run = "cd artifacts/mazari-corp && pnpm dev"

[env]
CI = "true"

[[artifacts]]
id = "artifacts/mazari-corp"

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
